```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
.env.*

# Build directories
dist/
build/
target/
.gradle/

# Editors
.vscode/
.idea/
*.swp
*.swo

# Logs and temp files
*.log
*.tmp

# Coverage
coverage/
htmlcov/
.coverage

# OS specific
.DS_Store
Thumbs.db

# Caching
.mypy_cache/
.pytest_cache/
```